{
  "artificial_signal_check": {
    "10_hz_alpha_greater_than_beta": true,
    "20_hz_beta_greater_than_alpha": true
  },
  "real_data_subject": 1,
  "tasks": {
    "2class": {
      "task_name": "左手 vs 右手",
      "input_shape": [
        40,
        30,
        5000
      ],
      "feature_shape": [
        40,
        480
      ],
      "feature_count": 480,
      "all_values_finite": true
    },
    "4class": {
      "task_name": "左手、右手、左腕、右腕",
      "input_shape": [
        80,
        30,
        5000
      ],
      "feature_shape": [
        80,
        480
      ],
      "feature_count": 480,
      "all_values_finite": true
    },
    "6class": {
      "task_name": "全部六类运动想象",
      "input_shape": [
        120,
        30,
        5000
      ],
      "feature_shape": [
        120,
        480
      ],
      "feature_count": 480,
      "all_values_finite": true
    }
  },
  "deterministic_repeat": true,
  "feature_config": {
    "feature_sets": [
      "time",
      "frequency"
    ],
    "input_shape": [
      40,
      30,
      5000
    ],
    "output_shape": [
      40,
      480
    ],
    "feature_order": "feature_type_then_channel_number",
    "time_features": [
      "mean",
      "standard_deviation",
      "variance",
      "root_mean_square",
      "peak_to_peak",
      "mean_absolute_value",
      "skewness",
      "kurtosis",
      "waveform_length",
      "zero_crossing_rate"
    ],
    "frequency": {
      "method": "Welch PSD",
      "sampling_rate_hz": 500,
      "nperseg": 500,
      "noverlap": 250,
      "bands_hz": [
        {
          "name": "alpha",
          "low": 8.0,
          "high": 13.0
        },
        {
          "name": "beta",
          "low": 13.0,
          "high": 30.0
        }
      ],
      "total_power_band_hz": [
        8.0,
        30.0
      ],
      "features_per_channel": [
        "absolute_band_power",
        "relative_band_power",
        "spectral_centroid",
        "normalized_spectral_entropy"
      ]
    },
    "uses_dataset_statistics": false,
    "standardization_note": "Feature standardization must be fitted inside each training fold."
  },
  "feature_name_examples": [
    "mean_ch_01",
    "mean_ch_02",
    "mean_ch_03",
    "mean_ch_04",
    "mean_ch_05",
    "mean_ch_06",
    "mean_ch_07",
    "mean_ch_08",
    "mean_ch_09",
    "mean_ch_10"
  ]
}
